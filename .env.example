# Translation Coverage Audit
# Copy to .env for local development. Do not commit real secrets.

SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_APP_URL=https://example.com
SCOPES=read_products,read_translations
DATABASE_URL=postgresql://app_user:app_password@localhost:5432/translation_coverage_audit
SHOP_CUSTOM_DOMAIN=
NODE_ENV=development

# Docker deployment placeholders
COMPOSE_PROJECT_NAME=translation-coverage-audit
APP_DB_NAME=translation_coverage_audit
APP_DB_USER=translation_coverage_audit_user
APP_DB_PASSWORD=replace_me
APP_HOST=translation-coverage-audit.example.com
CONTACT_EMAIL=
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
NODE_OPTIONS=
